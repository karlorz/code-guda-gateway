#!/usr/bin/env bash
set -euo pipefail

ARTIFACT_BASE="${CODE_GUDA_ARTIFACT_BASE:-{{ARTIFACT_BASE}}}"

if [[ -z "$ARTIFACT_BASE" || "$ARTIFACT_BASE" == "{{ARTIFACT_BASE}}" ]]; then
  printf 'CODE_GUDA_ARTIFACT_BASE is required for update-code-guda-gateway\n' >&2
  exit 2
fi

exec bash -c "$(curl -fsSL "${ARTIFACT_BASE%/}/install.sh")" -- "$@"