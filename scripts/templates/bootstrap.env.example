# Bootstrap-only settings for guda-gateway (no secrets).
# Copy to /etc/code-guda-gateway/bootstrap.env and adjust as needed.
# The gateway reads env vars only — source this file or point systemd EnvironmentFile= at it.
# Placeholders are filled by scripts/install-linux.sh; defaults match production paths.

ADDR={{LISTEN_ADDR}}
DB_PATH={{VAR_DIR}}/gateway.db
GUDA_MASTER_KEY_PATH={{ETC_DIR}}/master.key
GUDA_ADMIN_COOKIE_SECURE=true
